{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "编译资源文件",
            "type": "shell",
            "command": "windres",
            "args": ["resources.rc", "-o", "resources.o", "-I", "."],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "编译主程序",
            "type": "shell",
            "command": "g++",
            "args": ["-o", "SOCD_Bridge.exe", "SOCD_Bridge.cpp", "resources.o", "-lshell32", "-lgdi32", "-mwindows", "-static", "-O2", "-finput-charset=UTF-8", "-fexec-charset=GBK"],
            "group": "build",
            "dependsOn": "编译资源文件",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "生成安装包",
            "type": "shell",
            "command": "C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe",
            "args": ["installer.iss"],
            "group": { "kind": "build", "isDefault": true },
            "dependsOn": "编译主程序",
            "problemMatcher": []
        }
    ]
}


